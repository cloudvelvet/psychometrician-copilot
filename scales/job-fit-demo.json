    "skill_fit": { "label": "역량 적합", "method": "mean", "items": ["jf_skill_1", "jf_skill_2"] },
    "environment_fit": { "label": "환경 적합", "method": "mean", "items": ["jf_env_1", "jf_env_2"] },
