  "items": [
    { "id": "st_load_1", "text": "최근 해야 할 일이 감당하기 어렵게 느껴졌다.", "factor": "perceived_load", "reverse": false },
    { "id": "st_load_2", "text": "최근 일상적인 요구를 충분히 다룰 수 있다고 느꼈다.", "factor": "perceived_load", "reverse": true },
    { "id": "st_tension_1", "text": "최근 몸이나 마음이 쉽게 긴장되었다.", "factor": "tension", "reverse": false },
