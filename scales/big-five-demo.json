  "items": [
    { "id": "bf_o_1", "text": "나는 새로운 아이디어나 경험을 탐색하는 것을 즐긴다.", "factor": "openness", "reverse": false },
    { "id": "bf_o_2", "text": "나는 익숙한 방식만 고수하는 편이다.", "factor": "openness", "reverse": true },
    { "id": "bf_c_1", "text": "나는 해야 할 일을 체계적으로 마무리하는 편이다.", "factor": "conscientiousness", "reverse": false },
    { "id": "bf_c_2", "text": "나는 계획을 세워도 쉽게 미루는 편이다.", "factor": "conscientiousness", "reverse": true },
    { "id": "bf_e_1", "text": "나는 사람들과 어울릴 때 에너지를 얻는 편이다.", "factor": "extraversion", "reverse": false },
    { "id": "bf_e_2", "text": "나는 모임에서 먼저 말을 꺼내는 일이 드문 편이다.", "factor": "extraversion", "reverse": true },
    { "id": "bf_a_1", "text": "나는 다른 사람의 입장을 고려하려고 노력한다.", "factor": "agreeableness", "reverse": false },
    { "id": "bf_a_2", "text": "나는 의견이 다르면 상대를 쉽게 몰아붙이는 편이다.", "factor": "agreeableness", "reverse": true },
    { "id": "bf_n_1", "text": "나는 스트레스 상황에서 걱정이 커지는 편이다.", "factor": "neuroticism", "reverse": false },
    { "id": "bf_n_2", "text": "나는 압박감 속에서도 감정적으로 안정적인 편이다.", "factor": "neuroticism", "reverse": true },
    {
      "id": "bf_attention_1",
      "text": "응답 확인을 위해 이 문항은 '보통이다'를 선택해 주세요.",
